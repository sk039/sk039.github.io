    <id>https://sk039.github.io/2017/03/10/debootstrap安装MATE桌面/</id>
    <published>2017-03-10T03:55:48.000Z</published>
    <updated>2017-03-10T03:56:45.928Z</updated>
    
    <content type="html"><![CDATA[<h2 id="安装debootstrap"><a href="#安装debootstrap" class="headerlink" title="安装debootstrap"></a>安装debootstrap</h2><figure class="highlight bash"><table><tr><td class="gutter"><pre><div class="line">1</div><div class="line">2</div><div class="line">3</div><div class="line">4</div><div class="line">5</div><div class="line">6</div><div class="line">7</div><div class="line">8</div><div class="line">9</div><div class="line">10</div></pre></td><td class="code"><pre><div class="line">$ sudo apt-get install debootstrap</div><div class="line">$ debootstrap --arch=arm64 --include=mate-desktop-environment,lightdm-gtk-greeter,vim,net-tools,xorg,language-pack-zh-hans,fonts-wqy-microhei,ttf-wqy-microhei --components=main,restricted,multiverse,universe xenial /mnt/ http://mirrors.ustc.edu.cn/ubuntu-ports</div><div class="line">$ <span class="built_in">cd</span> ubuntu-xenial</div><div class="line">$ sudo mount -B /proc proc</div><div class="line">$ sudo mount -t tmpfs tmpfs tmp</div><div class="line">$ sudo cp /etc/resolv.conf etc</div><div class="line">$ xhost +</div><div class="line">$ <span class="built_in">export</span> DISPLAY=:0.0</div><div class="line">$ sudo chroot . </div><div class="line">$ useradd -m -p 123123 sk</div></pre></td></tr></table></figure>
<p>修改/etc/apt/sources.list<br><figure class="highlight plain"><table><tr><td class="gutter"><pre><div class="line">1</div></pre></td><td class="code"><pre><div class="line">deb http://mirrors.ustc.edu.cn/ubuntu-ports xenial main restricted multiverse universe</div></pre></td></tr></table></figure></p>
<blockquote>
<p>!!! rtkit包会导致进桌面卡住</p>
</blockquote>
]]></content>
    
